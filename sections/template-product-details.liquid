   <!-- Quantity & Add to Cart -->
<div class="flex items-center gap-3 mb-6" 
     x-data="{ qty: 1 }">

  <!-- Quantity Selector -->
  <div class="flex items-center border rounded-md">
    <button @click="if(qty>1) qty--" class="px-3 py-2">-</button>
    <span class="px-4" x-text="qty"></span>
    <button @click="qty++" class="px-3 py-2">+</button>
  </div>

  <!-- Add to Cart -->
  <button @click="addToCart(qty)"
          class="flex-1 bg-black text-white py-3 rounded-md flex items-center justify-center gap-2 cursor-pointer">
