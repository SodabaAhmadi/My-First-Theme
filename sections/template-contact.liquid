<!-- Contact Section -->
<div class="  max-w-2xl mx-auto px-6 py-16">
  <div class="max-w-[280px] mx-auto text-center">
    <h1 class="text-3xl font-bold mb-4">Contact</h1>
    <p class="text-gray-600 mb-8">
      Have a question, comment, or concern? Let us know and we will get in touch with you as soon as possible.
    </p>
  </div>

  {% form 'contact', class: 'space-y-4' %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <input type="text" name="contact[name]" placeholder="Name" class="w-full text-gray-700  border border-gray-400 rounded-md px-4 py-2">
      <input type="email" name="contact[email]" placeholder="Email" class="w-full text-gray-700  border border-gray-400 rounded-md px-4 py-2">
    </div>
    <input type="text" name="contact[phone]" placeholder="Phone" class="w-full text-gray-700  border border-gray-400 rounded-md px-4 py-2">
    <textarea name="contact[body]" placeholder="Comment" rows="5" class="w-full text-gray-700  border border-gray-400 rounded-md px-4 py-2"></textarea>
    <button type="submit" class="bg-black text-white px-6 py-2 rounded-md hover:bg-gray-800">
      Submit
    </button>
  {% endform %}
</div>


