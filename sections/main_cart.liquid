<!-- Cart Drawer -->
<div id="cartDrawer" class="fixed top-0 right-0 h-full bg-white shadow-lg transform translate-x-full
         transition-transform duration-300 ease-in-out flex flex-col z-50
         w-full sm:w-96">
  <!-- Header -->
  <div class="flex justify-between items-center p-4">
    <h2 class="text-xl font-semibold">Cart
      {% if cart.item_count > 0 %}
      <span class="text-gray-500 text-sm">{{cart.item_count}}</span>
      {% endif %}
    </h2>
    <button onclick="toggleCart()" class="text-gray-600 text-lg">
      {%- render 'icon-close' -%}
    </button>
  </div>

  <div class="flex-1 overflow-y-auto px-4 pt-1 pb-4">
    {% if cart.item_count == 0 %}
    <div class="flex flex-col items-center justify-center h-full text-center px-4">
      <p class="text-lg font-medium">Your cart is empty</p>
      <p class="text-sm text-gray-600 mt-2">Have an account? Log in to check out faster.</p>
      <a href="{{routes.all_products_collection_url}}"
        class="mt-4 inline-block px-6 py-2 bg-black text-white rounded-md hover:bg-gray-800">
        Continue shopping
      </a>
    </div>


    {% else %}

    <!-- Product List (Scrollable) -->
    <div class="flex-1 overflow-y-auto pl-4 pr-4 pb-4 space-y-4">

      {% for item in cart.items %}
      <!-- Product -->
      <div class="flex items-start justify-between py-2 border-b border-gray-200"
        x-data="{ qty: {{ item.quantity }}, price: {{ item.price }}, line: {{ forloop.index }} }">

        <a href="{{ item.url }}">
          {% if item.image %}
          <img src="{{ item.image | img_url: 'small' }}" alt="{{ item.title | escape }}"
            class="w-16 h-16 object-cover border">
          {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'w-16 h-16 object-cover border' }}
          {% endif %}
        </a>

        <div class="ml-3 flex-1">
          <a href="{{ item.url }}" class="font-medium text-sm block">
            {{ item.product.title | truncatewords: 5 }}
          </a>
          <span class="text-xs text-gray-500">{{ item.variant.title }}</span>

          <!-- Unit price -->
          <p class="text-sm mt-1">{{ item.price | money }}</p>

          <div class="flex items-center mt-2">
            <div class="border border-gray-200 p-1.5 flex items-center">
              <button type="button" class="px-2"
                @click="if (qty > 1) { qty--; $refs.hiddenInput.value = qty; $refs.hiddenInput.form.submit(); }">-</button>

              <!-- Editable input -->
              <input type="number" name="updates[]" id="updates_{{ forloop.index }}" x-model.number="qty"
                @change="$refs.hiddenInput.value = qty; $refs.hiddenInput.form.submit();" min="1" class="w-12 h-8 text-center outline-none 
       [appearance:textfield] 
       [&::-webkit-outer-spin-button]:appearance-none 
       [&::-webkit-inner-spin-button]:appearance-none" />

              <button type="button" class="px-2"
                @click="qty++; $refs.hiddenInput.value = qty; $refs.hiddenInput.form.submit();">+</button>

              <!-- Hidden input (syncs with Shopify cart form) -->
              {% comment %} <input type="hidden" name="updates[]" :value="qty" x-ref="hiddenInput" form="cart-form"> {%
              endcomment %}
            </div>

            <!-- Delete Button -->
            <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0"
              class="ml-3 text-gray-500 transition-transform duration-200 hover:-translate-y-1 hover:text-red-500">
              {% render 'icon-delete' %}
            </a>
          </div>
        </div>

        <!-- Line total (Live updating with Alpine) -->
        <p class="font-medium text-sm" x-text="'{{ cart.currency.symbol }}' + (qty * price / 100).toFixed(2)">
          {{ item.line_price | money }}
        </p>
      </div>
      {% endfor %}



    </div>

    {% endif %}
  </div>
  {% comment %} <!-- Gradient Overlay -->
  <div class="absolute bottom-40 w-full h-10 bg-gradient-to-b from-white/90 to-transparent pointer-events-none">
  </div> {% endcomment %}

  {% if cart.item_count > 0 %}

  <form action="{{ routes.cart_url }}" method="post" novalidate >

    <div class="  p-4 space-y-3">
      <!-- Discount Section -->
      <div class="pt-3.5 border-t border-gray-200 space-y-3 px-4">
        <div class="flex justify-between items-center cursor-pointer" onclick="toggleDiscount()">
          <span class="font-medium">Discount</span>
          <span id="discountIcon" class="text-xl">+</span>
        </div>
        <!-- Animated Discount Input -->
        <div id="discountForm" class="overflow-hidden max-h-0 transition-all duration-500 ease-in-out">
          <div class="mt-3 flex gap-2">
            <input type="text" placeholder="Discount code" class="flex-1 border rounded px-3 py-2 text-sm">
            <button class="bg-black text-white px-4 py-2 rounded text-sm">Apply</button>
          </div>
        </div>
      </div>

      <!-- Estimated Total -->
      <div class="border-t border-gray-200 pt-3">
        <p class="flex justify-between text-sm font-medium">
          <span>Estimated total</span>
          <span>{{cart.total_price | money}}</span>
        </p>
        <p class="text-xs text-gray-500">Taxes and shipping calculated at checkout.</p>
      </div>

      <!-- Checkout Buttons -->
      <button name="checkout" type="submit" class="w-full py-3 bg-black text-white rounded-lg font-medium">Check
        out</button>
      <button
        class="w-full py-3 bg-purple-600 text-white rounded-lg font-medium flex items-center justify-center gap-2">
        Shop
      </button>
      <button class="w-full py-3 bg-gray-900 text-white rounded-lg font-medium flex items-center justify-center gap-2">
        {%- render 'icon-google' -%}
        Pay
      </button>
    </div>


  </form>

  {% endif %}
</div>