<!-- Cart Drawer -->
<div id="cartDrawer" class="
    fixed top-0 right-0 h-full bg-white shadow-lg transform translate-x-full
    transition-transform duration-300 ease-in-out flex flex-col z-50
    w-full sm:w-96
  ">
  <!-- Header -->
  <div class="flex justify-between items-center p-4">
    <h2 class="text-xl font-semibold">
      Cart
      {% if cart.item_count > 0 %}
      <span class="text-gray-500 text-sm">{{ cart.item_count }}</span>
      {% endif %}
    </h2>
    <button onclick="toggleCart()" class="text-gray-600 text-lg">
      {%- render 'icon-close' -%}
    </button>
  </div>

  <div class="flex-1 overflow-y-auto px-4 pt-1 pb-4">
    {% if cart.item_count == 0 %}
    <div class="flex flex-col items-center justify-center h-full text-center px-4">
      <p class="text-lg font-medium">Your cart is empty</p>
      <p class="text-sm text-gray-600 mt-2">Have an account? Log in to check out faster.</p>
      <a href="{{routes.all_products_collection_url}}"
        class="mt-4 inline-block px-6 py-2 bg-black text-white rounded-md hover:bg-gray-800">
        Continue shopping
      </a>
    </div>

    {% else %}
    <!-- Product List (Scrollable) -->
    <div class="flex-1 overflow-y-auto pl-4 pr-4 pb-4 space-y-4">
      {% for item in cart.items %}
      <!-- Product -->
      <div class="flex items-start justify-between py-2 border-b border-gray-200"
        x-data="{ qty: {{ item.quantity }}, price: {{ item.price }}, line: {{ forloop.index }} }">
        <a href="{{ item.url }}">
          {% if item.image %}
          <img src="{{ item.image | img_url: 'small' }}" alt="{{ item.title | escape }}"
            class="w-16 h-16 object-cover border">
          {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'w-16 h-16 object-cover border' }}
          {% endif %}
        </a>

        <div class="ml-3 flex-1">
          <a href="{{ item.url }}" class="font-medium text-sm block">
            {{ item.product.title | truncatewords: 5 }}
          </a>
          <span class="text-xs text-gray-500">{{ item.variant.title }}</span>

          <!-- Unit price -->
          <p class="text-sm mt-1">{{ item.price | money }}</p>

          <div class="flex items-center mt-2">
            <div class="border border-gray-200 p-1.5 flex items-center">
              <button type="button" class="px-2"
                @click="if (qty > 1) { qty--; $refs.hiddenInput.value = qty; $refs.hiddenInput.form.submit(); }">
                -
              </button>

              <!-- Editable input -->
              <input type="number" name="updates[]" id="updates_{{ forloop.index }}" x-model.number="qty"
                @change="$refs.hiddenInput.value = qty; $refs.hiddenInput.form.submit();" min="1" class="
                                w-12 h-8 text-center outline-none
                                [appearance:textfield]
                                [&::-webkit-outer-spin-button]:appearance-none
                                [&::-webkit-inner-spin-button]:appearance-none
                            ">

              <button type="button" class="px-2"
                @click="qty++; $refs.hiddenInput.value = qty; $refs.hiddenInput.form.submit();">
                +
              </button>

              <!-- Hidden input (syncs with Shopify cart form) -->
              {% comment %}
              <input type="hidden" name="updates[]" :value="qty" x-ref="hiddenInput" form="cart-form">
              {% endcomment %}
            </div>

            <!-- Delete Button -->
            <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0"
              class="ml-3 text-gray-500 transition-transform duration-200 hover:-translate-y-1 hover:text-red-500">
              {% render 'icon-delete' %}
            </a>
          </div>
        </div>

        <!-- Line total (Live updating with Alpine) -->
        <p class="font-medium text-sm" x-text="'{{ cart.currency.symbol }}' + (qty * price / 100).toFixed(2)">
          {{ item.line_price | money }}
        </p>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% comment %}
  <!-- Gradient Overlay -->
  <div class="absolute bottom-40 w-full h-10 bg-gradient-to-b from-white/90 to-transparent pointer-events-none">
  </div>
  {% endcomment %}

  {% if cart.item_count > 0 %}
  <form action="{{ routes.cart_url }}" method="post" novalidate>
    <div class="  p-4 space-y-3">
      <!-- Discount Section -->
      <div class="pt-3.5 border-t border-gray-200 space-y-3 px-4">
        <div class="flex justify-between items-center cursor-pointer" onclick="toggleDiscount()">
          <span class="font-medium">Discount</span>
          <span id="discountIcon" class="text-xl">+</span>
        </div>
        <!-- Animated Discount Input -->
        <div id="discountForm" class="overflow-hidden max-h-0 transition-all duration-500 ease-in-out">
          <div class="mt-3 flex gap-2">
            <input type="text" placeholder="Discount code" class="flex-1 border rounded px-3 py-2 text-sm">
            <button class="bg-black text-white px-4 py-2 rounded text-sm">Apply</button>
          </div>
        </div>
      </div>

      <!-- Estimated Total -->
      <div class="border-t border-gray-200 pt-3">
        <p class="flex justify-between text-sm font-medium">
          <span>Estimated total</span>
          <span>{{ cart.total_price | money }}</span>
        </p>
        <p class="text-xs text-gray-500">Taxes and shipping calculated at checkout.</p>
      </div>

      <!-- Checkout Buttons -->
      <button name="checkout" type="submit" class="w-full py-3 bg-black text-white rounded-lg font-medium">
        Check out
      </button>
      <button
        class="w-full py-3 bg-purple-600 text-white rounded-lg font-medium flex items-center justify-center gap-2">
        Shop
      </button>
      <button class="w-full py-3 bg-gray-900 text-white rounded-lg font-medium flex items-center justify-center gap-2">
        {%- render 'icon-google' -%}
        Pay
      </button>
    </div>
  </form>
  {% endif %}
</div>






















































































































































<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Product Collection - Horizon Store</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            "custom-gray": "#f9fafb",
          },
        },
      },
    };
  </script>
  <style>
    .sort-option {
      transition: all 0.2s ease;
    }

    .sort-option:hover {
      background-color: #f9fafb;
    }

    .checkmark {
      opacity: 0;
      transition: opacity 0.2s ease;
    }

    .sort-option.selected .checkmark {
      opacity: 1;
    }

    .color-option {
      transition: all 0.2s ease;
    }

    .color-option:hover {
      background-color: #f9fafb;
    }

    .color-chip {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 8px;
    }

    .black {
      background-color: #000;
    }

    .white {
      background-color: #f0f0f0;
      border: 1px solid #ddd;
    }

    .blue {
      background-color: #3b82f6;
    }

    .green {
      background-color: #10b981;
    }

    .red {
      background-color: #ef4444;
    }

    .clear-btn {
      transition: all 0.2s ease;
    }

    .clear-btn:hover {
      color: #000;
      text-decoration: underline;
    }

    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }

    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>
</head>

<body class="font-sans text-gray-900">
  <!-- Navbar -->
  <header class="flex items-center justify-between px-6 py-4 border-b">
    <div class="text-xl font-bold">Horizon</div>
    <nav class="flex space-x-6">
      <a href="product-collection.html" class="font-semibold text-black">Shop</a>
      <a href="#" class="hover:text-gray-700">Contact</a>
    </nav>
    <div class="flex space-x-4 text-gray-600">
      <button><i class="fas fa-search w-5 h-5"></i></button>
      <button><i class="fas fa-user w-5 h-5"></i></button>
      <button><i class="fas fa-shopping-cart w-5 h-5"></i></button>
    </div>
  </header>

  <!-- Page Title -->
  <section class="px-6 py-10">
    <h1 class="text-3xl font-bold mb-6">Products</h1>

    <!-- Filters -->
    <div class="flex justify-between items-center mb-6 text-sm text-gray-700">
      <div class="flex space-x-6">
        <!-- Availability Dropdown -->
        <div class="relative group" x-data="{ open: false }" @click.outside="open = false">
          <button class="flex items-center focus:outline-none" @click="open = !open">
            Availability
            <i class="fas fa-chevron-down ml-1 text-xs transition-transform duration-200"
              :class="{'rotate-180': open}"></i>
          </button>
          <div
            class="absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-10 transition-all duration-200 ease-out origin-top"
            x-show="open" x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 transform scale-95"
            x-transition:enter-end="opacity-100 transform scale-100" x-transition:leave="transition ease-in duration-75"
            x-transition:leave-start="opacity-100 transform scale-100"
            x-transition:leave-end="opacity-0 transform scale-95" style="display: none">
            <div class="px-4 py-2 border-b border-gray-100 text-xs font-medium text-gray-500 uppercase tracking-wider">
              Availability
            </div>
            <label class="flex items-center px-4 py-2 hover:bg-custom-gray cursor-pointer">
              <input type="checkbox" class="rounded border-gray-300 text-black focus:ring-black mr-2" />
              <span class="text-sm">In stock</span>
            </label>
            <label class="flex items-center px-4 py-2 hover:bg-custom-gray cursor-pointer">
              <input type="checkbox" class="rounded border-gray-300 text-black focus:ring-black mr-2" />
              <span class="text-sm">Out of stock</span>
            </label>
          </div>
        </div>

        <!-- Color Dropdown -->
        <div class="relative" x-data="{ 
        open: false, 
        selectedColors: [],
        colors: [
          { name: 'Beige', value: '#e6d7a5' },
          { name: 'Black', value: '#000000' },
          { name: 'Blue', value: '#4b81a0' },
          { name: 'Brown', value: '#9b552b' },
          { name: 'Gray', value: '#7a7a7a' },
          { name: 'Dark Green', value: '#2b4430' },
          { name: 'Navy', value: '#1a1c38' },
          { name: 'Light Gray', value: '#d7cfcf' },
          { name: 'Purple', value: '#5a3b54' },
          { name: 'Red', value: '#8b2e22' },
          { name: 'White', value: '#ffffff', border: true },
          { name: 'Khaki', value: '#a49870' },
        ],
        toggleColor(color) {
          if (this.selectedColors.includes(color.name)) {
            this.selectedColors = this.selectedColors.filter(c => c !== color.name);
          } else {
            this.selectedColors.push(color.name);
          }
        },
        clearAll() {
          this.selectedColors = [];
        }
     }" @click.outside="open = false">
          <!-- Button -->
          <div class="flex items-center space-x-2">
            <button class="flex items-center focus:outline-none" @click="open = !open">
              <span>Color</span>
              <!-- Show selected color circles -->
              <!-- Show selected color circles -->
              <div class="flex items-center ml-2">
                <template x-for="color in colors.filter(c => selectedColors.includes(c.name))" :key="color.name">
                  <div class="w-4 h-4 rounded-full border -mr-[8px]"
                    :style="`background-color: ${color.value}; border-color: ${color.border ? '#ccc' : 'transparent'}`">
                  </div>
                </template>
              </div>

              <i class="fas fa-chevron-down ml-2 text-xs transition-transform duration-200"
                :class="{'rotate-180': open}"></i>
            </button>

            <!-- Clear button on the right -->
            <template x-if="selectedColors.length > 0">
              <button class="text-sm text-blue-600 hover:underline ml-2" @click="clearAll()">
                Clear all
              </button>
            </template>
          </div>

          <!-- Dropdown -->
          <div
            class="absolute left-0 mt-2 w-56 bg-white rounded-md shadow-lg p-4 z-10 transition-all duration-200 ease-out origin-top"
            x-show="open" x-transition style="display: none">
            <!-- Grid of colors -->
            <div class="grid grid-cols-4 gap-3">
              <template x-for="color in colors" :key="color.name">
                <div class="relative cursor-pointer" @click="toggleColor(color)">
                  <div class="w-8 h-8 rounded-full border flex items-center justify-center"
                    :style="`background-color: ${color.value}; border-color: ${color.border ? '#ddd' : 'transparent'}`">
                    <!-- Circle border highlight when selected -->
                    <div x-show="selectedColors.includes(color.name)"
                      class="absolute w-9 h-9 rounded-full border-2 border-black -m-0.5"></div>
                  </div>
                </div>
              </template>
            </div>
          </div>
        </div>
      </div>
      <div class="flex space-x-6 items-center">
        <span class="text-gray-500">176 items</span>

        <!-- Sort Dropdown -->
        <div class="relative group" x-data="{ open: false, selected: 'Alphabetically, A-Z' }"
          @click.outside="open = false">
          <button class="flex items-center focus:outline-none" @click="open = !open">
            Sort
            <i class="fas fa-chevron-down ml-1 text-xs transition-transform duration-200"
              :class="{'rotate-180': open}"></i>
          </button>
          <div
            class="absolute right-0 mt-2 w-56 bg-white rounded-md shadow-lg py-2 z-10 transition-all duration-200 ease-out origin-top"
            x-show="open" x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 transform scale-95"
            x-transition:enter-end="opacity-100 transform scale-100" x-transition:leave="transition ease-in duration-75"
            x-transition:leave-start="opacity-100 transform scale-100"
            x-transition:leave-end="opacity-0 transform scale-95" style="display: none">
            <!-- Featured -->
            <div class="sort-option px-4 py-2 cursor-pointer" :class="{'selected': selected === 'Featured'}"
              @click="selected = 'Featured'">
              <div class="flex justify-between items-center">
                <span class="text-sm">Featured</span>
                <span class="checkmark text-black">✓</span>
              </div>
            </div>

            <!-- Best Selling -->
            <div class="sort-option px-4 py-2 cursor-pointer" :class="{'selected': selected === 'Best selling'}"
              @click="selected = 'Best selling'">
              <div class="flex justify-between items-center">
                <span class="text-sm">Best selling</span>
                <span class="checkmark text-black">✓</span>
              </div>
            </div>

            <div class="border-t border-gray-100 my-1"></div>

            <!-- Alphabetically, A-Z -->
            <div class="sort-option px-4 py-2 cursor-pointer selected"
              :class="{'selected': selected === 'Alphabetically, A-Z'}" @click="selected = 'Alphabetically, A-Z'">
              <div class="flex justify-between items-center">
                <span class="text-sm">Alphabetically, A-Z</span>
                <span class="checkmark text-black">✓</span>
              </div>
            </div>

            <!-- Alphabetically, Z-A -->
            <div class="sort-option px-4 py-2 cursor-pointer" :class="{'selected': selected === 'Alphabetically, Z-A'}"
              @click="selected = 'Alphabetically, Z-A'">
              <div class="flex justify-between items-center">
                <span class="text-sm">Alphabetically, Z-A</span>
                <span class="checkmark text-black">✓</span>
              </div>
            </div>

            <!-- Price, low to high -->
            <div class="sort-option px-4 py-2 cursor-pointer" :class="{'selected': selected === 'Price, low to high'}"
              @click="selected = 'Price, low to high'">
              <div class="flex justify-between items-center">
                <span class="text-sm">Price, low to high</span>
                <span class="checkmark text-black">✓</span>
              </div>
            </div>

            <!-- Price, high to low -->
            <div class="sort-option px-4 py-2 cursor-pointer" :class="{'selected': selected === 'Price, high to low'}"
              @click="selected = 'Price, high to low'">
              <div class="flex justify-between items-center">
                <span class="text-sm">Price, high to low</span>
                <span class="checkmark text-black">✓</span>
              </div>
            </div>

            <!-- Date, old to new -->
            <div class="sort-option px-4 py-2 cursor-pointer" :class="{'selected': selected === 'Date, old to new'}"
              @click="selected = 'Date, old to new'">
              <div class="flex justify-between items-center">
                <span class="text-sm">Date, old to new</span>
                <span class="checkmark text-black">✓</span>
              </div>
            </div>

            <!-- Date, new to old -->
            <div class="sort-option px-4 py-2 cursor-pointer" :class="{'selected': selected === 'Date, new to old'}"
              @click="selected = 'Date, new to old'">
              <div class="flex justify-between items-center">
                <span class="text-sm">Date, new to old</span>
                <span class="checkmark text-black">✓</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Grid Column Toggle -->
        <div class="flex space-x-2">
          <!-- 4 columns (default selected) -->
          <button id="grid4Btn" onclick="setGrid(4)" class="p-1 border rounded bg-gray-200">
            <i class="fas fa-th"></i>
          </button>
          <!-- 12 columns -->
          <button id="grid12Btn" onclick="setGrid(12)" class="p-1 border rounded hover:bg-gray-200">
            <i class="fas fa-grip-lines"></i>
          </button>
        </div>
      </div>
    </div>

    <!-- Product Grid -->
    <div id="productGrid" class="grid grid-cols-2 md:grid-cols-4 gap-6">


      <!-- Example product -->
      <div x-data="{ 
  activeImage: 1, 
  images: [
    'https://picsum.photos/400/500?random=22',
    'https://picsum.photos/400/500?random=23',
    'https://picsum.photos/400/500?random=24'
  ],
  transitioning: true,
  originalImage: 1,
  showModal: false,
  quantity: 1,
  selectedColor: 'Pumice',
  selectedSize: 'M',
  modalImages: [
    'https://picsum.photos/500/600?random=1',
    'https://picsum.photos/500/600?random=2',
    'https://picsum.photos/500/600?random=3'
  ],

  showNext() {
    this.originalImage = this.activeImage;
    this.next();
  },
  resetImage() {
    this.activeImage = this.originalImage;
  },
  next() {
    this.transitioning = true;
    this.activeImage++;
  },
  prev() {
    this.transitioning = true;
    this.activeImage--;
  },
  handleTransitionEnd() {
    if (this.activeImage === this.images.length + 1) {
      this.transitioning = false;
      this.activeImage = 1;
    }
    if (this.activeImage === 0) {
      this.transitioning = false;
      this.activeImage = this.images.length;
    }
  }
}" class="w-64">

        <!-- Product Card -->
        <div class="relative overflow-hidden h-[360px] bg-gray-100 group">
          <!-- Add to Cart Button -->
          <div class="absolute bottom-2 right-2 z-20 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition">
            <button @click="showModal = true"
              class="bg-white rounded-full shadow transition-all duration-300 ease-in-out group h-8 w-8 hover:w-[64px] overflow-hidden flex items-center justify-start pl-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-700 flex-shrink-0" fill="none"
                viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 
            1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 
            1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 
            1 5.513 7.5h12.974c.576 0 1.059.435 1.119 
            1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 
            .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 
            1 1-.75 0 .375.375 0 0 1 .75 0Z" />
              </svg>
              <span
                class="ml-2 text-gray-700 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap">Add</span>
            </button>
          </div>
        </div>

        <!-- Product title + price -->
        <div class="mt-2">
          <p class="text-sm">Striped Waffle LS Tee</p>
          <p class="text-sm font-medium mt-1">$75.00</p>
        </div>

        <!-- MODAL -->
        <div x-show="showModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50"
          @click.self="showModal = false" x-transition>

          <!-- Modal container -->
          <div class="bg-white w-full max-w-2xl h-[85vh] rounded-lg overflow-hidden flex relative">

            <!-- Close button -->
            <button @click="showModal = false" class="absolute top-3 right-3  p-2 rounded-full z-10">
              ✕
            </button>

            <!-- Left column: product images -->
            <div class="w-1/2 h-full overflow-y-auto rounded-tr-[16px]  scrollbar-hide">
              <template x-for="(image, index) in modalImages" :key="index">
                <img :src="image" alt="Product image" class="w-full h-auto block pb-1" />
              </template>
            </div>

            <!-- Right column: product details -->
            <div class="w-1/2 h-full flex flex-col">
              <!-- Title + Price -->
              <div class="p-6 pb-2">
                <h2 class="text-2xl font-bold mb-2">
                  Michael Shaggy Wool Cardigan
                </h2>
                <p class="text-lg mt-10 mb-4">$280.00</p>
              </div>

              <!-- Color + Size (scrollable area) -->
              <div class="px-6 flex-1 mt-4">
                <div class="max-h-28 overflow-y-auto pr-2 scrollbar-thin scrollbar-thumb-gray-300">
                  <!-- Colors -->
                  <div class="mb-4">
                    <p class="text-sm font-medium mb-2">Color</p>
                    <div class="flex gap-2 flex-wrap px-2">
                      <template x-for="color in [
                          { name: 'Pumice', class: 'bg-gray-400' },
                          { name: 'Black', class: 'bg-black' },
                          { name: 'Red', class: 'bg-red-400' }
                          ]" :key="color.name">
                        <span @click="selectedColor = color.name" :class="[
                            'w-10 h-10 rounded-full cursor-pointer border-2 transition',
                            color.class,
                            selectedColor === color.name 
                              ? 'ring-2 ring-gray-500 border-white' 
                              : 'hover:ring-2 hover:ring-gray-300 hover:border-white'
                          ]">
                        </span>
                      </template>
                    </div>
                  </div>


                  <!-- Sizes -->
                  <div>
                    <p class="text-sm font-medium mb-2">Size</p>
                    <div class="flex gap-2 flex-wrap">
                      <template x-for="size in ['XS','S','M','L','XL','XXL','XXXL']" :key="size">
                        <button @click="selectedSize = size" :class="selectedSize === size 
                            ? 'bg-black text-white border-gray-300' 
                            : 'bg-white text-gray-700 border border-gray-300 hover:border-gray-500'"
                          class="px-4 py-2 rounded-[16px] transition min-w-[54px] text-center">
                          <span x-text="size"></span>
                        </button>
                      </template>
                    </div>
                  </div>


                </div>
              </div>

              <!-- Bottom actions -->
              <div class="p-6  space-y-4 bg-white">
                <!-- Quantity + Add to cart -->
                <div class="flex space-x-2">
                  <div class="flex items-center border rounded-lg px-3 py-3 space-x-7">
