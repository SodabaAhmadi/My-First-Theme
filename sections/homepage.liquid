  <script>
    function setGrid(cols) {
      const grid = document.getElementById("productGrid");
      const products = grid.querySelectorAll("img");

      // buttons
      const btn4 = document.getElementById("grid4Btn");
      const btn12 = document.getElementById("grid12Btn");

      // reset button styles
      btn4.classList.remove("bg-gray-200");
      btn12.classList.remove("bg-gray-200");

      // remove old grid-cols classes
      grid.classList.remove(
        "grid-cols-2",
        "md:grid-cols-4",
        "md:grid-cols-12"
      );

      if (cols === 4) {
        grid.classList.add("grid-cols-2", "md:grid-cols-4");
        products.forEach((img) => {
          img.classList.remove("h-40");
          img.classList.add("h-[400px]");
        });
        btn4.classList.add("bg-gray-200"); // highlight 4-col
      } else if (cols === 12) {
        grid.classList.add("grid-cols-2", "md:grid-cols-12");
        products.forEach((img) => {
          img.classList.remove("h-[400px]");
          img.classList.add("h-40");
        });
        btn12.classList.add("bg-gray-200"); // highlight 12-col
      }
    }

    // run once on page load to set 4-col default selected
    window.onload = () => setGrid(4);
  </script>
