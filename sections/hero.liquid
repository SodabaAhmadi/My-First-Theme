<!-- sections/hero-custom.liquid -->
<section class="relative">
  {% if section.settings.image != blank %}
    <img 
      src="{{ section.settings.image | image_url: width: 2000 }}" 
      alt="{{ section.settings.image.alt | escape }}" 
      class="w-full h-[400px] object-cover"
    >
  {% else %}
    <!-- Fallback placeholder if no image is chosen -->
    <img 
      src="{{ 'hero-default.jpg' | asset_url }}" 
      alt="Hero" 
      class="w-full h-[400px] object-cover"
    >
  {% endif %}

  <div class="absolute inset-0 flex flex-col items-center justify-center text-center text-white bg-black/30">
    <h1 class="text-4xl md:text-6xl font-bold mb-4">
      {{ section.settings.heading }}
      
    </h1>
    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link }}" class="px-6 py-3 border border-white text-white rounded-lg hover:bg-white hover:text-black transition">
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New arrivals"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}
