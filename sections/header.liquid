<!-- Add this CSS (to hide [x-cloak] elements before Alpine loads) -->
<style>
  [x-cloak] {
    display: none !important;
  }

  /* Cart badge style */
  .cart-badge {
    position: absolute;
    top: -6px;
    right: -6px;
    background: black;
    color: white;
    font-size: 10px;
    font-weight: bold;
    border-radius: 9999px;
    padding: 2px 5px;
    line-height: 1;
  }

  .hide-scrollbar {
    -ms-overflow-style: none;
    /* IE and Edge */
    scrollbar-width: none;
    /* Firefox */
  }

  .hide-scrollbar::-webkit-scrollbar {
    display: none;
    /* Chrome, Safari, Opera */
  }
</style>

<div class="relative bg-white" x-data="{ mobileMenuOpen: false, searchOpen: false, searchText: '' }">
  <div class="mx-auto px-4 sm:px-6">
    <!-- MOBILE NAVBAR -->
    <div class="flex items-center justify-between py-4 md:hidden">

      <!-- LEFT SIDE (Hamburger + Search) -->
      <div class="flex items-center space-x-3">

        <!-- Hamburger -->
        <button type="button" class="bg-white p-2 inline-flex items-center justify-center focus:outline-none"
          @click="mobileMenuOpen = true">
          {% render 'icon-menu' %}
        </button>

        <!-- Search -->
        <button aria-label="Search" class="text-gray-700 hover:text-gray-900 cursor-pointer" @click="searchOpen = true">
          {% render 'search', class: "w-5 h-5" %}
        </button>
      </div>

      <!-- CENTER (Shop Name) -->
      <div class="flex-1 flex justify-center">
        <h1 class="text-lg font-bold truncate">{{shop.name}}</h1>
      </div>

      <!-- RIGHT SIDE (Account + Cart) -->

      <div class="flex items-center space-x-4">
        <!-- Account -->
        <div class="relative" x-data="{ accountOpen: false }">
          <button aria-label="Account" class="text-gray-500 hover:text-gray-900 focus:outline-none"
            @click="accountOpen = !accountOpen">
            {% render 'icon-account', class: 'w-5 h-5' %}
          </button>

          <!-- Desktop Dropdown -->
          <div x-show="accountOpen && window.innerWidth >= 768" @click.away="accountOpen = false" x-transition x-cloak
            class="absolute right-0 mt-2 w-84 rounded-xl shadow-lg bg-white p-4 z-50 hidden md:block">
            <h3 class="text-gray-800 font-medium mb-3">Account</h3>

            {% unless shop.customer_accounts_enabled %}
            <button class="w-full mb-2 bg-indigo-600 text-white font-medium py-2 px-4 rounded-lg">
              Sign in with Shop
            </button>
            {% endunless %}

            <button class="w-full mb-3 bg-black text-white font-medium py-2 px-4 rounded-lg">
              Other sign in options
            </button>
            <div class="grid grid-cols-2 gap-2">
              <a href="/account/orders"
                class="flex items-center justify-center border rounded-lg py-2 text-gray-700 hover:bg-gray-50">
                <span class="mr-2">🧾</span> Orders
              </a>
              <a href="/account/profile"
                class="flex items-center justify-center border rounded-lg py-2 text-gray-700 hover:bg-gray-50">
                <span class="mr-2">👤</span> Profile
              </a>
            </div>
          </div>

          <!-- Mobile Bottom Sheet -->
          <div x-show="accountOpen && window.innerWidth < 768"
            x-transition:enter="transform transition ease-out duration-300" x-transition:enter-start="translate-y-full"
            x-transition:enter-end="translate-y-0" x-transition:leave="transform transition ease-in duration-200"
            x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full" x-cloak
            class="fixed inset-x-0 bottom-0 bg-white shadow-lg rounded-t-2xl p-5 z-50 md:hidden">
            <!-- Header with Close Button -->
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-gray-800 font-medium">Account</h3>
              <button class="text-gray-600 hover:text-gray-900 p-2 rounded-md" @click="accountOpen = false">
                {%- render 'icon-close' -%}
              </button>
            </div>

            <!-- Sign in buttons -->
            {% unless shop.customer_accounts_enabled %}
            <button class="w-full mb-2 bg-indigo-600 text-white font-medium py-2 px-4 rounded-lg">
              Sign in with Shop
            </button>
            {% endunless %}


            <button class="w-full mb-4 bg-black text-white font-medium py-2 px-4 rounded-lg">
              Other sign in options
            </button>

            <!-- Links -->
            <div class="grid grid-cols-2 gap-2">
              <a href="/account/orders"
                class="flex items-center justify-center border rounded-lg py-2 text-gray-700 hover:bg-gray-50">
                <span class="mr-2">🧾</span> Orders
              </a>
              <a href="/account/profile"
                class="flex items-center justify-center border rounded-lg py-2 text-gray-700 hover:bg-gray-50">
                <span class="mr-2">👤</span> Profile
              </a>
            </div>
          </div>
        </div>

        <!-- Cart -->
        <button type="button" onclick="toggleCart()" aria-label="Cart"
          class="relative text-gray-700 hover:text-gray-900">
          {% render 'cart', class: 'w-5 h-5' %}
          <span class="cart-badge">3</span>
        </button>

      </div>

    </div>

    <!-- DESKTOP NAVBAR -->
    <div class="hidden md:block w-full bg-white " x-data="{ openMenu: null }">
      <!-- STORE NAME / STORE LOGO -->
      <div class="md:flex justify-between items-center py-6 md:space-x-10">

        <div class="flex items-center space-x-10 lg:flex-1">
          <h1 class="text-xl font-bold truncate">{{ shop.name }}</h1>

          <!-- NAVIGATION MENU -->
          <div class="flex space-x-10">
            {%- for link in linklists.main-menu.links -%}
            {%- if link.links != blank -%}
            <div class="relative" @mouseenter="openMenu = '{{ link.title | handle }}'" @mouseleave="openMenu = null">
              <button type="button" class="inline-flex items-center text-base text-gray-500 hover:text-gray-900">
                {{ link.title }}
                {% render 'icon-dropdown' %}
              </button>
            </div>
            {%- else -%}
            <a href="{{ link.url }}" class="text-base text-gray-500 hover:text-gray-900">
              {{ link.title }}
            </a>
            {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <!-- RIGHT SIDE ICONS -->
        <div class="flex items-center justify-end flex-1 space-x-5">
          <!-- Search -->
          <button aria-label="Search" class="text-gray-500 hover:text-gray-900 cursor-pointer"
            @click="searchOpen = true">
            {% render 'search', class: "w-5 h-5" %}
          </button>


          <!-- Account Dropdown -->
          <div class="relative" x-data="{ accountOpen: false }">
            <button aria-label="Account" class="text-gray-500 hover:text-gray-900 focus:outline-none"
              @click="accountOpen = !accountOpen">
              {% render 'icon-account', class: 'w-5 h-5' %}
            </button>

            <!-- Dropdown Panel -->
            <div x-show="accountOpen" @click.away="accountOpen = false" x-transition x-cloak
              class="absolute right-0 mt-2 w-84 rounded-xl shadow-lg bg-white p-4 z-50">
              <h3 class="text-gray-800 font-medium mb-3">Account</h3>

              <!-- Sign in buttons -->
              {% unless shop.customer_accounts_enabled %}
              <button class="w-full mb-2 bg-indigo-600 text-white font-medium py-2 px-4 rounded-lg">
                Sign in with Shop
              </button>
              {% endunless %}



              <button class="w-full mb-3 bg-black text-white font-medium py-2 px-4 rounded-lg">
                Other sign in options
              </button>

              <!-- Links -->
              <div class="grid grid-cols-2 gap-2">
                <a href="/account/orders"
                  class="flex items-center justify-center border rounded-lg py-2 text-gray-700 hover:bg-gray-50">
                  <span class="mr-2">🧾</span> Orders
                </a>
                <a href="/account/profile"
                  class="flex items-center justify-center border rounded-lg py-2 text-gray-700 hover:bg-gray-50">
                  <span class="mr-2">👤</span> Profile
                </a>
              </div>
            </div>
          </div>


          <!-- Cart -->
          <button type="button" onclick="toggleCart()" aria-label="Cart"
            class="relative text-gray-700 hover:text-gray-900">
            {% render 'cart', class: 'w-5 h-5' %}
            {%- if cart.item_count > 0 -%}
            <span class="cart-badge">{{ cart.item_count }}</span>
            {%- endif -%}

          </button>

        </div>

      </div>


      <!-- DROPDOWN ROWS (appear full-width under navbar) -->
      {%- for link in linklists.main-menu.links -%}
      {%- if link.links != blank -%}
      <div class="border-t border-gray-200" x-show="openMenu === '{{ link.title | handle }}'"
        @mouseenter="openMenu = '{{ link.title | handle }}'" @mouseleave="openMenu = null" x-transition x-cloak>
        <div class="max-w-7xl mx-auto flex flex-col px-6 py-6 space-y-2">
          {%- for sublink in link.links -%}
          <a href="{{ sublink.url }}" class="p-3 rounded-lg hover:bg-gray-100 block">
            <p class="text-gray-900 text-base font-medium">{{ sublink.title }}</p>
          </a>
          {%- endfor -%}
        </div>
      </div>
      {%- endif -%}
      {%- endfor -%}
    </div>


  </div>




  <!-- MOBILE MENU CONTAINER -->

  <div class="absolute z-10 top-0 inset-x-0 p-2 transform origin-top-left md:hidden h-screen flex flex-col"
    x-show="mobileMenuOpen" x-cloak x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-x-full" x-transition:enter-end="opacity-100 translate-x-0"
    x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-x-0"
    x-transition:leave-end="opacity-0 -translate-x-full">

    <div class="shadow-lg rounded-lg bg-white w-full flex flex-col flex-1">
      <div class="p-5 divide-y-2 divide-gray-50 flex-1 overflow-y-auto">

        <!-- MOBILE MENU HEADER TITLE PLUS CLOSE BUTTON -->
        <div class="flex items-center justify-between pb-3">
          <div>
            <h1 class="text-lg text-gray-500">{{shop.name}}</h1>
          </div>

          <div class="-mr-2">

            <button type="button" class="bg-white rounded-md p-2 text-gray-500" @click="mobileMenuOpen = false">
              {%- render 'icon-close' -%}
            </button>

          </div>
        </div>

        <!-- NAVIGATION LINKS FOR MOBILE MENU -->
        <div class="pt-3">
          <nav class="grid gap-y-7">
            {%- for link in linklists.main-menu.links-%}
            {%- assign link_handle = link.handle | replace: '-', '_' -%}
            {%- if link.links !=blank -%}
            <div x-data="{ {{link_handle}}: false }" class=" relative">
              <button x-on:click="{{link_handle}} =! {{link_handle}}" type="button"
                class="text-base text-gray-500 hover:text-gray-900 flex items-center justify-between w-full">
                {{ link.title }}
                {%- render 'icon-dropdown' -%}
              </button>

              <div x-show="{{link_handle}}" class="grid gap-y-7 py-3">
                {%- for sublink in link.links -%}
                <a href="#" class="-m-3 p-3 flex items-center rounded-md text-gray-500 hover:text-gray-50">
                  <span class="ml-3 text-base font-medium text-gray-500">
                    {{sublink.title}}
                  </span>
                </a>
                {%- endfor -%}
              </div>

            </div>
            {%- else -%}
            <div class=" relative">
              <a href="{{link.url}}"
                class="-m-3 p-3 flex items-center rounded-md text-gray-500 hover:text-gray-900 hover:bg-gray-50">{{link.title}}</a>
            </div>

            {%- endif -%}

            {%- endfor -%}

          </nav>
        </div>
      </div>

      <!-- FIXED SCROLLABLE PRODUCTS ROW AT BOTTOM -->
      <div class="p-4 border-t border-gray-200 overflow-x-auto bg-white">
        <div class="flex space-x-6">
          <!-- Product 1 -->
          <div class="min-w-[200px]">
            <img src="https://via.placeholder.com/400x500" alt="Product 1" class="w-full h-56 object-cover rounded-md">
            <p class="mt-3 text-base font-medium text-gray-800 truncate">Product One</p>
            <p class="text-base text-gray-500">$199.00</p>
          </div>

          <!-- Product 2 -->
          <div class="min-w-[200px]">
            <img src="https://via.placeholder.com/400x500" alt="Product 2" class="w-full h-56 object-cover rounded-md">
            <p class="mt-3 text-base font-medium text-gray-800 truncate">Product Two</p>
            <p class="text-base text-gray-500">$149.00</p>
          </div>

          <!-- Product 3 -->
          <div class="min-w-[200px]">
            <img src="https://via.placeholder.com/400x500" alt="Product 3" class="w-full h-56 object-cover rounded-md">
            <p class="mt-3 text-base font-medium text-gray-800 truncate">Product Three</p>
            <p class="text-base text-gray-500">$179.00</p>
          </div>

          <!-- Product 4 -->
          <div class="min-w-[200px]">
            <img src="https://via.placeholder.com/400x500" alt="Product 4" class="w-full h-56 object-cover rounded-md">
            <p class="mt-3 text-base font-medium text-gray-800 truncate">Product Four</p>
            <p class="text-base text-gray-500">$120.00</p>
          </div>
        </div>
      </div>

    </div>
  </div>




  <!-- SEARCH MODAL -->
  <div x-show="searchOpen" x-transition x-cloak
    class="fixed inset-0 bg-gray-500/75 transition-opacity z-50 flex justify-center items-start pt-20 px-4">

    <!-- Modal Container -->
    <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl max-h-[80vh] overflow-y-scroll hide-scrollbar">
      <div class="p-6">
        <!-- Close button -->
        <div class="flex justify-end">
          <button @click="searchOpen = false" class="text-gray-600 hover:text-gray-900">✕</button>
        </div>

        <!-- Search Bar -->
        <div class="relative flex items-center mt-4">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            {% render 'search', class: 'h-5 w-5 text-gray-400' %}
          </div>
          <input type="text" placeholder="Search" x-model="searchText"
            class="w-full pl-10 pr-4 py-3 border-b-2 border-gray-200 focus:outline-none focus:border-gray-800 transition-colors">
        </div>

        <!-- 1️⃣ Default state (recent + products) -->
        <div x-show="!searchText" class="mt-8">
          <!-- Recently Viewed -->
          <div class="mb-6">
            <h3 class="font-medium text-gray-700 mb-3">Recently viewed</h3>
            <div class="grid grid-cols-2 gap-6">
              <!-- Example static items (replace with Shopify logic if needed) -->
              <div class="group relative text-left">
                <img src="https://via.placeholder.com/200" class="w-full h-40 object-cover rounded-md">
                <div class="mt-2 text-gray-800 text-sm">Sofia Lightweight Turtleneck Top<br>$92.00</div>
              </div>
              <div class="group relative text-left">
                <img src="https://via.placeholder.com/200" class="w-full h-40 object-cover rounded-md">
                <div class="mt-2 text-gray-800 text-sm">Michael Shaggy Wool Cardigan<br>$281.00</div>
              </div>
            </div>
          </div>

          <!-- Products -->
          <div>
            <h3 class="font-medium text-gray-700 mb-3">Products</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-8">
              {%- for product in collections.all.products limit: 4 -%}
              <div class="group relative text-left">
                <div class="w-full min-h-50 bg-gray-200 overflow-hidden group-hover:opacity-75">
                  {% if product.featured_image %}
                  <a href="{{ product.url }}">
                    <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}"
                      class="w-full h-full object-center object-cover" />
                  </a>
                  {% else %}
                  <div class="w-full h-48 bg-gray-100 flex items-center justify-center text-sm text-gray-400">
                    No image
                  </div>
                  {% endif %}
                </div>
                <!-- Product Info -->
                <div class="font-medium mt-4 text-gray-800">
                  <p>{{ product.title }}</p>
                  {% if product.price %}
                  <p>{{ product.price | money }}</p>
                  {% endif %}
                </div>
              </div>
              {%- endfor -%}
            </div>
          </div>
        </div>

        <!-- 2️⃣ Typing state (categories + products + view all) -->
        <div x-show="searchText" class="mt-8">
          <!-- Category Tags -->
          <div class="flex flex-wrap gap-3 mb-6">
            <button class="px-3 py-1 rounded-full bg-gray-100 text-sm text-gray-700 hover:bg-gray-200">dossy</button>
            <button class="px-3 py-1 rounded-full bg-gray-100 text-sm text-gray-700 hover:bg-gray-200">dekalb
              heavy</button>
            <button class="px-3 py-1 rounded-full bg-gray-100 text-sm text-gray-700 hover:bg-gray-200">canty
              dossy</button>
            <button class="px-3 py-1 rounded-full bg-gray-100 text-sm text-gray-700 hover:bg-gray-200">timothy
              dossy</button>
          </div>

          <!-- Search Results -->
          <div>
            <h3 class="font-medium text-gray-700 mb-3">Products</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-8">
              {%- for product in collections.all.products limit: 4 -%}
              <div class="group relative text-left">
                <div class="w-full min-h-50 bg-gray-200 overflow-hidden group-hover:opacity-75">
                  {% if product.featured_image %}
                  <a href="{{ product.url }}">
                    <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}"
                      class="w-full h-full object-center object-cover" />
                  </a>
                  {% else %}
                  <div class="w-full h-48 bg-gray-100 flex items-center justify-center text-sm text-gray-400">
                    No image
                  </div>
                  {% endif %}
                </div>
                <div class="font-medium mt-4 text-gray-800">
                  <p>{{ product.title }}</p>
                  {% if product.price %}
                  <p>{{ product.price | money }}</p>
                  {% endif %}
                </div>
              </div>
              {%- endfor -%}
            </div>
          </div>

          <!-- View All -->
          <div class="flex justify-center mt-6">
            <a href="/search?q=" x-bind:href="'/search?q=' + searchText"
              class="px-6 py-2 bg-black text-white rounded-md hover:bg-gray-800 transition">
              View all
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>